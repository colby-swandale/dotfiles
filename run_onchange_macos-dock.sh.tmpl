{{- if (eq .chezmoi.os "darwin") -}}
#!/bin/bash

dockutil --remove all
dockutil --add /Applications/Safari.app
dockutil --add /System/Applications/Music.app
dockutil --add /Applications/iTerm.app
dockutil --add /Applications/Slack.app
dockutil --add /Applications/Notion.app
dockutil --add /Applications/Visual\ Studio\ Code.app
dockutil --add /Applications/Insomnia.app
dockutil --add /Applications/Sizzy.app
dockutil --add /Applications/TablePlus.app

dockutil --add '~/Downloads' --view grid --display folder
{{- end -}}